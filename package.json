{
  "name": "@mtayfur/opencode-prompt-enhancer",
  "version": "0.1.0",
  "description": "OpenCode plugin that rewrites rough drafts into stronger prompts.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./tui": "./dist/plugins/prompt-enhancer.js"
  },
  "oc-plugin": [
    "tui"
  ],
  "scripts": {
    "build": "bun run scripts/build.mjs",
    "setup": "./install.sh",
    "setup:uninstall": "./install.sh --uninstall",
    "typecheck": "bunx tsc -p tsconfig.json"
  },
  "files": [
    "README.md",
    "dist",
    "index.ts",
    "plugins",
    "scripts"
  ],
  "engines": {
    "opencode": ">=1.17.19"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.17.19",
    "@opencode-ai/sdk": "^1.17.19",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-typescript": "^7.27.1",
    "@opencode-ai/plugin": "^1.17.19",
    "@opencode-ai/sdk": "^1.17.19",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "babel-preset-solid": "^1.9.12",
    "solid-js": "^1.9.12",
    "typescript": "^5.8.2"
  },
  "keywords": [
    "opencode",
    "plugin",
    "prompt",
    "tui"
  ]
}
