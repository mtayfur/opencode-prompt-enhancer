{
  "name": "@mtayfur/opencode-prompt-enhancer",
  "version": "0.1.0",
  "description": "OpenCode plugin that rewrites rough drafts into stronger prompts.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./tui": "./plugins/prompt-enhancer.tsx"
  },
  "oc-plugin": [
    "tui"
  ],
  "scripts": {
    "typecheck": "bunx tsc -p tsconfig.json"
  },
  "files": [
    "README.md",
    "index.ts",
    "plugins"
  ],
  "engines": {
    "opencode": ">=1.3.14"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opencode-ai/sdk": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "devDependencies": {
    "typescript": "5.8.2"
  },
  "keywords": [
    "opencode",
    "plugin",
    "prompt",
    "tui"
  ]
}
